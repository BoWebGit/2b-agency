# SMTP для контактної форми (/api/contact).
# Скопіюй цей файл у .env.local і встав реальні дані з хостингу пошти.
# .env.local у .gitignore — секрети не потраплять у git.

# SMTP-сервер вихідної пошти. УВАГА: mail.boweb.com.ua вказує на Vercel (не на пошту),
# тож використовуємо прямий хостнейм cPanel-сервера хостера.
SMTP_HOST=uashared38.twinservers.net
# 465 = SSL/TLS (рекомендовано), 587 = STARTTLS.
SMTP_PORT=465
# Повний логін поштової скриньки та її пароль.
SMTP_USER=hello@boweb.com.ua
# ⚠️ Справжній пароль тут НЕ пиши — тільки в .env.local (він у .gitignore).
SMTP_PASS=

# Куди приходять заявки (за замовчуванням = SMTP_USER).
CONTACT_TO=hello@boweb.com.ua
# Адреса-відправник (має належати домену; за замовчуванням = SMTP_USER).
CONTACT_FROM=hello@boweb.com.ua

# GA4 Measurement ID (G-XXXXXXXXXX). Публічний (інлайниться в клієнт), тож не секрет.
# Аналітика підключається лише коли ця змінна задана.
NEXT_PUBLIC_GA_ID=

# Telegram-сповіщення про нові заявки (додатково до email, /api/contact).
# 1) Створи бота через @BotFather в Telegram → команда /newbot → скопіюй токен.
# 2) Напиши боту будь-що (натисни Start), тоді відкрий у браузері:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    і візьми "chat":{"id": ...} зі свого повідомлення - це і є TELEGRAM_CHAT_ID.
# Якщо змінні не задані - Telegram-сповіщення просто мовчки пропускається,
# email продовжує працювати як і раніше.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
